# OPTIONAL. If set, AI calls use the Anthropic API (required for Vercel).
# If NOT set, the app spawns your local Claude Code CLI (`claude -p`) instead —
# install with: npm install -g @anthropic-ai/claude-code, then run `claude` to log in.
ANTHROPIC_API_KEY=

# OPTIONAL. Model alias passed to the local CLI (only used when no API key).
# Examples: sonnet | haiku | opus | default
# "default" omits --model so the CLI uses your session's default model —
# use this if a model alias isn't available on your plan.
CLAUDE_CLI_MODEL=

# OPTIONAL. Rate limits for /api/ai/* per client IP (defaults: 6/min, 60/day).
RATE_LIMIT_PER_MINUTE=6
RATE_LIMIT_PER_DAY=60

# OPTIONAL. Groq provider (recommended for Vercel if you don't have an Anthropic key).
# Get a key at https://console.groq.com. Model names change often - override if needed.
GROQ_API_KEY=
GROQ_MODEL_SMART=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.3-70b-versatile

# OPTIONAL. Force a provider instead of auto-detection: anthropic | groq | cli
AI_PROVIDER=

# OPTIONAL. Single-user login. Auth activates ONLY when BOTH are set - leave
# unset locally for no login; set both on Vercel to lock the site to you.
# AUTH_PASSWORD: pick a long, unique password (a passphrase of 4+ random words).
# AUTH_SECRET:   random signing key - generate with:  openssl rand -base64 32
AUTH_PASSWORD=
AUTH_SECRET=
LOGIN_RATE_LIMIT_PER_MINUTE=5
